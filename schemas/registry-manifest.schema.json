{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/semantic-packages/registry-manifest.schema.json",
  "title": "Semantic package registry manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "sources", "members"],
  "properties": {
    "formatVersion": {"const": 1},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "root", "roles"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9_-]*$"
          },
          "root": {"type": "string", "minLength": 1},
          "roles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "theory-authored",
                "dependency",
                "package-authored",
                "package-consumer-authored"
              ]
            }
          }
        }
      }
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "address", "sha256", "role"],
        "properties": {
          "source": {"type": "string", "minLength": 1},
          "address": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "id", "version"],
            "properties": {
              "kind": {"type": "string", "minLength": 1},
              "id": {"type": "string", "minLength": 1},
              "version": {"type": "string", "minLength": 1}
            }
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "role": {
            "enum": [
              "theory-authored",
              "dependency",
              "package-authored",
              "package-consumer-authored"
            ]
          }
        }
      }
    }
  }
}
